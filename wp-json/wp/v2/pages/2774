a-mp-item>return to previous<\/span>\r\n              <\/button>\r\n            <\/div>\r\n          <\/div>\r\n          <!-- Step #5 - Final -->\r\n          <div class=\"cost-calculator-step\">\r\n            <div class=\"row md:flex-nowrap gap-12\">\r\n              <!-- Col -->\r\n              <div class=\"cost-calculator-col w-full sm:w-1\/2\">\r\n                <div class=\"mb-layout-sm last-child-mb-0\">\r\n                  <h2 class=\"mb-2\">Final Details<\/h2>\r\n                <\/div>\r\n                <!-- Form Group -->\r\n                <h5>Do you have a budget allocated?<\/h5>\r\n                <div class=\"w-full form-selectors-group form-col xl:col-4\">\r\n                  <div class=\"form-selector\" data-cursor=\"hover\">\r\n                    <input type=\"radio\" id=\"cost-0\" name=\"budget\" value=\"No yet\">\r\n                    <label for=\"cost-0\">No yet<\/label>\r\n                  <\/div>\r\n                  <div class=\"form-selector\" data-cursor=\"hover\">\r\n                    <input type=\"radio\" id=\"cost-1\" name=\"budget\" value=\"\u00a36K - \u00a310K\">\r\n                    <label for=\"cost-1\"><span class=\"currency-symbol\">\u00a3<\/span>6K &#8211; <span class=\"currency-symbol\">\u00a3<\/span>10K<\/label>\r\n                  <\/div>\r\n                  <div class=\"form-selector\" data-cursor=\"hover\">\r\n                    <input type=\"radio\" id=\"cost-3\" name=\"budget\" value=\"\u00a310K - \u00a315K\">\r\n                    <label for=\"cost-3\"><span class=\"currency-symbol\">\u00a3<\/span>10K &#8211; <span class=\"currency-symbol\">\u00a3<\/span>15K<\/label>\r\n                  <\/div>\r\n                  <div class=\"form-selector\" data-cursor=\"hover\">\r\n                    <input type=\"radio\" id=\"cost-4\" name=\"budget\" value=\"\u00a315K - \u00a320K\">\r\n                    <label for=\"cost-4\"><span class=\"currency-symbol\">\u00a3<\/span>15K &#8211; <span class=\"currency-symbol\">